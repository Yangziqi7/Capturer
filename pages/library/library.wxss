.library-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  margin-bottom: 28rpx;
}

.title,
.subtitle {
  display: block;
}

.title {
  margin-top: 12rpx;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.08;
}

.subtitle {
  margin-top: 16rpx;
  color: #66736e;
  font-size: 28rpx;
  line-height: 1.55;
}

.library-head button {
  flex: 0 0 190rpx;
}

.empty {
  display: flex;
  min-height: 540rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  padding: 44rpx;
  text-align: center;
}

.empty-icon {
  font-size: 82rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 900;
}

.empty .muted {
  max-width: 520rpx;
  font-size: 28rpx;
  line-height: 1.55;
}

.empty button {
  width: 320rpx;
  margin-top: 16rpx;
}

.sticker-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.sticker-card {
  padding: 18rpx;
}

.sticker-preview {
  position: relative;
  display: flex;
  height: 300rpx;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 10rpx solid #ffffff;
  border-radius: 26rpx;
  background: #fffdf5;
  box-shadow: 7rpx 7rpx 0 #17211f;
}

.sticker-preview.comic {
  border-color: #17211f;
  background: #fff3f0;
}

.sticker-preview.brand {
  border-color: #7eb8ff;
  background: #eef7ff;
}

.sticker-preview image {
  width: 100%;
  height: 100%;
}

.mock-object {
  display: flex;
  width: 160rpx;
  height: 160rpx;
  align-items: center;
  justify-content: center;
  border: 10rpx solid #ffffff;
  border-radius: 38rpx;
  background: #f7b267;
}

.mock-object.comic {
  border-color: #17211f;
  background: #8ecae6;
}

.mock-object.brand {
  border-color: #7eb8ff;
  background: #ffd166;
}

.mock-object text {
  font-size: 76rpx;
}

.sticker-label {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  left: 14rpx;
  padding: 10rpx 8rpx;
  border-radius: 12rpx;
  background: #ffd166;
  color: #17211f;
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
}

.card-copy {
  margin-top: 18rpx;
}

.card-copy text {
  display: block;
}

.card-copy text:first-child {
  font-size: 28rpx;
  font-weight: 900;
}

.card-copy text:last-child {
  margin-top: 6rpx;
  color: #66736e;
  font-size: 22rpx;
}

.card-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 16rpx;
}

.card-actions button {
  min-height: 70rpx;
  font-size: 24rpx;
}

.pack-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 26rpx;
  padding: 28rpx;
}

.pack-title {
  display: block;
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.pack-panel .muted {
  display: block;
  margin-top: 8rpx;
  color: #66736e;
  font-size: 24rpx;
  line-height: 1.5;
}

.pack-panel button {
  flex: 0 0 190rpx;
}
